# GrabMedia Backend Environment Variables

# Port to run on (default: 5000)
PORT=5000

# Frontend URL for CORS (default: http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# Optional: path to a Netscape-format cookies file for Instagram login
# Export from browser using "Get cookies.txt LOCALLY" Chrome extension
# INSTAGRAM_COOKIES_FILE=/path/to/cookies.txt
